# ----------------------------------------------------------------------------
# Postgres credentials — read by docker-compose to provision the container
# AND by NestJS (via @nestjs/config) to build the Prisma connection.
# Single source of truth: keep these three + DATABASE_URL in sync.
# ----------------------------------------------------------------------------
POSTGRES_USER=app_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=nest_app

# Prisma connection string.
# host = localhost because Nest runs on the host (PG container exposes 5432).
DATABASE_URL=postgresql://app_user:change_me@localhost:5432/nest_app

# ----------------------------------------------------------------------------
# NestJS runtime
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
APP_NAME=nest-app

# ----------------------------------------------------------------------------
# JWT
# JWT_SECRET: at least 32 bytes of randomness, base64 or hex.
# Generate locally with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER commit a real secret — only this placeholder is checked in.
# ----------------------------------------------------------------------------
JWT_SECRET=change_me_to_a_64_char_hex_string
# Token lifetime. nestjs/jwt accepts: "60s", "15m", "1h", "7d", "30d", etc.
JWT_EXPIRES_IN=7d