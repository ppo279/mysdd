// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


// 004: EnumStatus was previously 6 values; `ocr_processing` and
// `ocr_done` were OCR-era zombies (CONTEXT §1.1, MiniMax-M3 直接吃图，
// 无 OCR 阶段). They were removed via enum rebuild migration
// `20260630120000_drop_enum_status_ocr_zombies` (rename → new →
// alter → drop). Code uses only these 4 valid states.
enum EnumStatus {
  pending
  solving
  done
  failed
}

// (Q7) lock: classify `failed` Problems by the path that produced
// the failure. Five codes match the five catch paths that call
// `markFailed`:
//   - upload_storage_failed    — slice 1: storage.put threw on upload
//   - upload_db_update_failed  — slice 1: DB update failed after put
//   - image_read_failed        — slice 2: solver's storage.read threw
//   - solver_timeout           — slice 2: AbortError after SOLVER_TIMEOUT_MS
//   - solver_failed            — slice 2: generic SDK / parse / network
enum EnumFailureCode {
  upload_storage_failed
  upload_db_update_failed
  image_read_failed
  solver_timeout
  solver_failed
}

// 家长端用户
model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  passwordHash String
  createTime DateTime @default(now())
  updatedAt DateTime?  @updatedAt
  // 反向关系：一个用户可以有多个孩子
  children Child[]
  
}
// 孩子
model Child {
  id    Int     @id @default(autoincrement())
  name String
  grade Int
  createTime DateTime @default(now())
  // 关系
  // 属于一个User
  userId Int
  user User @relation(fields: [userId], references: [id])
  // 反向关系：一个孩子可以有多个题目
  problems Problem[]

  // 003 #2: a DB-level CHECK constraint enforces `1 <= grade <= 12`.
  // The `prisma-client-js` generator (used here) does not surface
  // `@@check` in the schema language as of Prisma 7.8, so the
  // constraint is declared in SQL only and the schema is the
  // documentation. The matching migration is
  // `prisma/migrations/20260629110000_add_child_grade_range_check/`.
  // A future `CreateChildDto` will mirror the same range with
  // `@Min(1) @Max(12)` so the API layer rejects bad input BEFORE
  // the round trip to the DB.
}
// 题目
model Problem {
  id    Int     @id @default(autoincrement())
  imageUrl String
  ocrText String?
  status EnumStatus @default(pending)
  createTime DateTime @default(now())
  updatedAt DateTime?  @updatedAt
  // (Q7) lock: when status='failed', `failureCode` classifies the
  // failure path (5 codes — see EnumFailureCode doc) and
  // `failureReason` carries the underlying exception message for
  // debugging. Both NULL when status != 'failed'.
  failureCode EnumFailureCode?
  failureReason String?
  // 一对多（Problem 必须属于一个 Chile）
  childId Int
  child   Child @relation(fields: [childId], references: [id])
  // (A) lock: a Problem has at most one Solution (1:0..1 singleton).
  // The UNIQUE constraint on Solution.problemId — added in migration
  // `solution_one_to_zero_or_one` — enforces the cardinality at the
  // storage layer. A second `solution.create` for the same problem
  // fails with Prisma P2002, which the solver does not catch (we
  // don't expect a re-solve path in this slice).
  solution Solution?
}
// 解题思路
model Solution {
  id    Int     @id @default(autoincrement())
  content String
  createTime DateTime @default(now())
  // 用了哪个大模型
  model String?
  // LLM token 使用量 (Anthropic SDK finalMessage().usage 全量 JSON)
  // 字段名 'token' 已废 — 实际只存 output_tokens 一数字, 误导读者以为是
  // input/output/total 中任一总称; 改 'usage' 后字段名 + 形状都对齐 SDK
  // 见 CONTEXT §Language '解题思路' 条目 (C 锁)
  usage Json?
  // (A) lock: at most one Solution per Problem. UNIQUE enforces the
  // 1:0..1 singleton cardinality at the storage layer.
  problemId Int     @unique
  // 反向关系
  problem  Problem @relation(fields: [problemId], references: [id])
}
